# Agentic Molecular and Materials Discovery Workbench
# Copy to .env and fill in your paths.

# Path to the REINVENT 4 de novo prior model file
REINVENT_PRIOR_PATH=/path/to/REINVENT4/priors/reinvent.prior

# Path to the MatterGen CLI binary (in its separate venv)
MATTERGEN_BIN=/path/to/mattergen-upstream/.venv/bin/mattergen-generate

# Path to the xTB binary (in its conda env)
XTB_BIN=/path/to/miniconda3/envs/xtb_env/bin/xtb

# Path to the ChEMBL reference fingerprint pickle
CHEMBL_REFERENCE_PATH=data/chembl_reference.pkl

# Materials Project API key (register at materialsproject.org)
MP_API_KEY=
